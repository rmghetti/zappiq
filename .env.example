# ═══════════════════════════════════════════════
# ZappIQ — Environment Variables (consolidado)
# ═══════════════════════════════════════════════
# Cópia pra .env local. Em produção (Fly), usar `fly secrets set`.
# Nenhum valor real aqui — só placeholders.

NODE_ENV=development

# ── Database (Supabase PostgreSQL) ────────────
# DATABASE_URL usa pooler (porta 6543 no Supabase pgbouncer) para app runtime
# DIRECT_URL usa conexão direta (porta 5432) para Prisma migrate
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Redis (Upstash em prod, redis local em dev) ──
REDIS_URL=redis://localhost:6379
# Em prod: rediss://default:<token>@<region>.upstash.io:6379 (TLS obrigatório)

# ── Auth ──────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_EXPIRES_IN=7d

# ── Anthropic (Claude LLM) ───────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# Fallback acionado via runbook em caso de rate limit:
LLM_FALLBACK_ON_RATELIMIT=claude-haiku-4-5

# ── OpenAI (fallback embeddings + Whisper) ────
OPENAI_API_KEY=sk-xxx

# ── Voyage AI (embeddings primários) ──────────
VOYAGE_API_KEY=pa-xxx
EMBEDDING_PROVIDER=voyage          # voyage | openai
EMBEDDING_MODEL=voyage-3           # ou text-embedding-3-small se openai
EMBEDDING_DIM=1024                 # 1024 voyage-3 | 1536 openai small

# ── WhatsApp Business API (Meta) ──────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=zappiq-webhook-secret-2026
WHATSAPP_API_VERSION=v21.0

# ── Google Calendar ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Frontend URLs ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Python RAG Service ────────────────────────
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_SECRET=dev-rag-secret-2026

# ── BullMQ concurrency tuning (workers) ───────
BULLMQ_LLM_CONCURRENCY=10
BULLMQ_MESSAGE_CONCURRENCY=20

# ── Observabilidade (OpenTelemetry) ───────────
# Deixar vazio / OTEL_SDK_DISABLED=true até ter provider ativo
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=zappiq-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64(instance_id:token)>
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
# Sampling: 1.0 em dev, 0.1 em prod
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ── LGPD / modo operacional ───────────────────
# Lista de org_ids separados por vírgula para isolamento emergencial (runbook sec 6)
BLOCKED_ORG_IDS=
# Maintenance mode: API retorna 503 {"maintenance": true} em todas as rotas
MAINTENANCE_MODE=false

# ── Backups (referência ADR-0002) ─────────────
# Bucket S3 para dumps semanais — CREDENCIAIS só em prod via fly secrets
BACKUP_S3_BUCKET=zappiq-backups-prod
BACKUP_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — via fly secrets, nunca no .env commitado

# ── DPO / contato LGPD ────────────────────────
DPO_EMAIL=dpo@zappiq.com
