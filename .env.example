# ═══════════════════════════════════════════════
# ZappIQ — Environment Variables
# ═══════════════════════════════════════════════

NODE_ENV=development

# ── Database (Supabase PostgreSQL) ────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_EXPIRES_IN=7d

# ── Anthropic (Claude LLM) ───────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI (Embeddings + Whisper) ─────────────
OPENAI_API_KEY=sk-xxx

# ── WhatsApp Business API (Meta) ──────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=zappiq-webhook-secret-2026
WHATSAPP_API_VERSION=v21.0

# ── Google Calendar ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Frontend URLs ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Python RAG Service ────────────────────────
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_SECRET=dev-rag-secret-2026
