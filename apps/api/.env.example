# ── Server ──
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3003,http://localhost:3000

# ── Database (Supabase PostgreSQL) ──
DATABASE_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Auth ──
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Anthropic (Claude AI) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI (Embeddings + Whisper) ──
OPENAI_API_KEY=sk-...

# ── WhatsApp Business API (Meta) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=zappiq-webhook-secret-2026
WHATSAPP_API_VERSION=v21.0

# ── Google Calendar ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
