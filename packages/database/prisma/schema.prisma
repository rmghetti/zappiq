generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, uuidOssp(map: "uuid-ossp")]
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum PlanType {
  STARTER
  GROWTH
  SCALE
  BUSINESS
  ENTERPRISE
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  AGENT
  AUDITOR
}

enum ConversationStatus {
  OPEN
  WAITING
  ASSIGNED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  LOCATION
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum CampaignType {
  BROADCAST
  TRIGGER
  SEQUENCE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
}

enum FlowTriggerType {
  KEYWORD
  FIRST_CONTACT
  SCHEDULE
  MANUAL
  EVENT
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

// LGPD Art. 7 + Art. 11 — bases legais de tratamento
enum LegalBasis {
  CONSENT               // Art. 7, I / Art. 11, I
  CONTRACT              // Art. 7, V
  LEGAL_OBLIGATION      // Art. 7, II
  LEGITIMATE_INTEREST   // Art. 7, IX
  VITAL_INTERESTS       // Art. 7, VII
  PUBLIC_INTEREST       // Art. 7, III
  CREDIT_PROTECTION     // Art. 7, X
  HEALTH_PROTECTION     // Art. 11, II, f
}

// Tipos de requisição do titular — LGPD Art. 18
enum DataSubjectRequestType {
  ACCESS          // confirmação + acesso
  CORRECTION      // correção
  ANONYMIZATION   // anonimização
  PORTABILITY     // portabilidade
  DELETION        // eliminação
  CONSENT_REVOKE  // revogação de consentimento
  INFORMATION     // informação sobre compartilhamento
}

enum DataSubjectRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  EXPIRED
}

// ═══════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════

model Organization {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  plan                      PlanType @default(STARTER)
  whatsappPhoneNumberId     String?
  whatsappBusinessAccountId String?
  whatsappAccessToken       String?
  settings                  Json     @default("{}")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // LGPD — retenção customizável por organização (dias).
  // Default conservador: 1825d (5 anos) audit / 730d (2 anos) soft-deleted.
  auditRetentionDays        Int      @default(1825)
  softDeleteRetentionDays   Int      @default(730)
  dpoEmail                  String?  // Art. 41 — contato do encarregado

  // ── Trial (14 dias com cap de custo LLM) ────────────────
  // trialStartedAt/trialEndsAt: janela do período grátis.
  // trialCostCapUsd: teto de LLM que o tenant pode queimar no trial
  // para não impactar margem em signups curiosos/abusivos.
  // trialConverted: marca que o trial virou assinatura paga.
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  trialCostCapUsd    Float       @default(15.00)
  trialConverted     Boolean     @default(false)
  isTrialActive      Boolean     @default(true)

  // ── Billing cycle sinc com Stripe ───────────────────────
  billingCycle       String?     // "monthly" | "annual"
  subscriptionStatus String?     // active | past_due | canceled | trialing

  users              User[]
  contacts           Contact[]
  conversations      Conversation[]
  campaigns          Campaign[]
  flows              Flow[]
  knowledgeBases     KnowledgeBase[]
  templates          MessageTemplate[]
  dataSubjectRequests DataSubjectRequest[]
  tenantUsageMonthly TenantUsageMonthly[]
  qaPairs            QAPair[]

  // ── Self-service AI training (maturação da IA pelo próprio cliente) ──
  // Score 0-100 cacheado. Atualizado a cada mutação relevante (upload de doc,
  // criação de Q&A, preenchimento de survey). Exposto no dashboard como
  // "termômetro" guiando o cliente ao próximo passo de qualificação da IA.
  aiReadinessScore   Int         @default(0)
  aiReadinessUpdatedAt DateTime?
  // Data em que o cliente finalizou a configuração inicial recomendada
  // (survey mínimo + 1 doc/URL + 3 Q&As). Marco usado para campanhas de
  // ativação e para o NPS do onboarding.
  aiTrainingReadyAt  DateTime?

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════
// TenantUsageMonthly — H10 unit economics por tenant
// Agregado denormalizado atualizado por job diário.
// Permite responder "esse cliente dá lucro?" em milissegundos.
// ═══════════════════════════════════════════════════════════
model TenantUsageMonthly {
  id                   String   @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Janela mensal no formato YYYY-MM (ex: "2026-04").
  periodYearMonth      String
  // Consumo bruto observado.
  llmCostUsd           Float    @default(0)
  llmInputTokens       BigInt   @default(0)
  llmOutputTokens      BigInt   @default(0)
  aiMessagesProcessed  Int      @default(0)
  broadcastsSent       Int      @default(0)
  conversationsOpened  Int      @default(0)
  conversationsClosed  Int      @default(0)
  conversationsAiResolved    Int      @default(0)
  conversationsHumanResolved Int      @default(0)
  handoffsCount        Int      @default(0)
  // Receita reconhecida no período (derivada do plano × cycle).
  revenueBrlCents      Int      @default(0)
  // Custo da infra atribuído ao tenant (fly/supabase/loki) — rateio proporcional.
  infraCostUsd         Float    @default(0)
  // Gross margin derivada = (revenue - llmCost - infraCost) / revenue.
  grossMarginPercent   Float?
  computedAt           DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([organizationId, periodYearMonth])
  @@index([periodYearMonth])
  @@map("tenant_usage_monthly")
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  name                  String
  passwordHash          String
  role                  UserRole @default(AGENT)
  avatar                String?
  isOnline              Boolean  @default(false)
  maxConcurrentChats    Int      @default(5)
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]
  deletedConversations  Conversation[] @relation("DeletedConversations")
  messages              Message[]
  auditLogs             AuditLog[]
  createdAt             DateTime @default(now())

  @@index([organizationId])
  @@map("users")
}

model Contact {
  id                 String     @id @default(cuid())
  whatsappId         String
  phone              String
  name               String?
  email              String?
  company            String?
  avatarUrl          String?
  tags               String[]   @default([])
  customFields       Json       @default("{}")
  leadScore          Int        @default(0)
  leadStatus         LeadStatus @default(NEW)
  funnelStage        String     @default("new")
  birthDate          DateTime?
  lastInteractionAt  DateTime?
  consentMarketing   Boolean    @default(false)
  consentMarketingAt DateTime?
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  deals              Deal[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([whatsappId, organizationId])
  @@index([organizationId])
  @@index([phone])
  @@index([leadStatus])
  @@map("contacts")
}

model Conversation {
  id               String             @id @default(cuid())
  status           ConversationStatus @default(OPEN)
  channel          String             @default("whatsapp")
  sentiment        Sentiment?
  urgency          Urgency?
  summary          String?
  csatScore        Int?
  assignedToId     String?
  assignedTo       User?              @relation(fields: [assignedToId], references: [id])
  contactId        String
  contact          Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages         Message[]
  internalNotes    InternalNote[]
  currentFlowState Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  closedAt         DateTime?
  deletedAt        DateTime?          // LGPD Art. 16 — marcação de exclusão
  deletedById      String?
  deletedBy        User?              @relation("DeletedConversations", fields: [deletedById], references: [id])
  deletionReason   String?            // motivo (DSR, operacional, purge por retenção)
  anonymizedAt     DateTime?          // LGPD Art. 12 — anonimização de PII

  @@index([organizationId])
  @@index([contactId])
  @@index([status])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("conversations")
}

model Message {
  id                String           @id @default(cuid())
  whatsappMessageId String?          @unique
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  content           String
  mediaUrl          String?
  mediaType         String?
  templateName      String?
  status            MessageStatus    @default(SENT)
  conversationId    String
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId          String?
  sender            User?            @relation(fields: [senderId], references: [id])
  isFromBot         Boolean          @default(false)
  aiConfidence      Float?
  metadata          Json?
  createdAt         DateTime         @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  templateId     String?
  template       MessageTemplate? @relation(fields: [templateId], references: [id])
  audienceFilter Json
  scheduledAt    DateTime?
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  readCount      Int            @default(0)
  repliedCount   Int            @default(0)
  failedCount    Int            @default(0)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  completedAt    DateTime?

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model Flow {
  id             String          @id @default(cuid())
  name           String
  description    String?
  nodes          Json
  edges          Json
  isActive       Boolean         @default(false)
  version        Int             @default(1)
  triggerType    FlowTriggerType
  triggerConfig  Json?
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@map("flows")
}

model KnowledgeBase {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      KBDocument[]
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("knowledge_bases")
}

model KBDocument {
  id              String        @id @default(cuid())
  title           String
  sourceType      String
  sourceUrl       String?
  content         String
  chunks          KBChunk[]
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@map("kb_documents")
}

model KBChunk {
  id         String                          @id @default(cuid())
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json?
  documentId String
  document   KBDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("kb_chunks")
}

// ═══════════════════════════════════════════════════════════════════
// QAPair — Perguntas & Respostas editáveis pelo cliente
// ─────────────────────────────────────────────────────────────────
// Estrutura explícita (pergunta → resposta) para casos em que o cliente
// quer "fixar" uma resposta sem depender de RAG de documento longo.
// Ingerido como chunks no vector store, mas mantido como registro
// canônico editável no CRUD. Categoria opcional para agrupamento
// (ex.: "horário de atendimento", "política de trocas", "pricing").
// ═══════════════════════════════════════════════════════════════════
model QAPair {
  id             String       @id @default(cuid())
  question       String
  answer         String
  category       String?
  priority       Int          @default(0)       // ordem de exibição / peso no RAG
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // ID do chunk correspondente no vector store — permite resync sem duplicar.
  ragChunkId     String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("qa_pairs")
}

model Deal {
  id             String   @id @default(cuid())
  title          String
  value          Decimal?
  stage          String   @default("new")
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId String
  closedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([contactId])
  @@map("deals")
}

model MessageTemplate {
  id              String   @id @default(cuid())
  name            String
  category        String
  language        String   @default("pt_BR")
  headerType      String?
  headerContent   String?
  bodyText        String
  footerText      String?
  buttons         Json?
  metaStatus      String   @default("PENDING")
  metaTemplateId  String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@map("message_templates")
}

model InternalNote {
  id             String       @id @default(cuid())
  content        String
  authorId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("internal_notes")
}

// LGPD Art. 37 (ROPA) + Art. 46 (segurança) + Art. 48 (incidentes)
// Cadeia hash garante detecção de adulteração. Append-only via policy de banco.
model AuditLog {
  id             String      @id @default(cuid())
  sequence       BigInt      @default(autoincrement())  // ordem estrita p/ cadeia
  action         String                                  // e.g. "conversation.delete"
  resource       String                                  // e.g. "conversation"
  resourceId     String?                                 // id do recurso tocado
  purpose        String?                                 // LGPD Art. 6 — finalidade
  legalBasis     LegalBasis?                             // LGPD Art. 7/11
  dataSubjectId  String?                                 // contactId quando toca dados pessoais
  details        Json?
  before         Json?                                   // snapshot antes (forense)
  after          Json?                                   // snapshot depois
  ipAddress      String?
  userAgent      String?
  hash           String?                                 // SHA-256 do registro (null em linhas legacy)
  prevHash       String?                                 // hash do registro anterior (chain)
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  organizationId String
  anonymizedAt   DateTime?                               // LGPD Art. 16 — marcado ao anonimizar
  createdAt      DateTime    @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([dataSubjectId])
  @@index([createdAt])
  @@index([sequence])
  @@map("audit_logs")
}

// LGPD Art. 18 — requisições do titular dos dados
model DataSubjectRequest {
  id             String                   @id @default(cuid())
  type           DataSubjectRequestType
  status         DataSubjectRequestStatus @default(PENDING)
  requesterEmail String                                      // email do titular
  requesterName  String?
  contactId      String?                                     // Contact.id se identificado
  reason         String?                                     // justificativa do titular
  responseData   Json?                                       // payload da resposta (para ACCESS/PORTABILITY)
  handledById    String?                                     // user.id do operador
  rejectionReason String?
  dueDate        DateTime                                    // prazo legal (15 dias — Art. 19)
  completedAt    DateTime?
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([contactId])
  @@index([dueDate])
  @@map("data_subject_requests")
}

model Consent {
  id        String    @id @default(cuid())
  contactId String
  type      String
  status    String
  grantedAt DateTime?
  revokedAt DateTime?
  channel   String?
  createdAt DateTime  @default(now())

  @@index([contactId])
  @@map("consents")
}
