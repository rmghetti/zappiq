# ═══════════════════════════════════════════════════════════════════
# ZappIQ · .env.production.example
#
# Copie este arquivo para .env.production (NAO COMMITADO) e preencha
# com os valores rotacionados. O deploy-production.sh faz `source` deste
# arquivo antes de chamar `fly secrets set`.
#
# .env.production esta em .gitignore · nunca suba pro git.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase (Postgres) ─────────────────────────────────────────────
# Formato pooler (pgbouncer, porta 6543)
DATABASE_URL="postgresql://postgres.<project>:<NEW_PASSWORD>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Formato direto (prisma migrate, porta 5432)
DIRECT_URL="postgresql://postgres.<project>:<NEW_PASSWORD>@<region>.pooler.supabase.com:5432/postgres"

# ── JWT (rotacionar: openssl rand -base64 64) ───────────────────────
JWT_SECRET="<NEW_JWT_SECRET_64B_BASE64>"

# ── Redis (Upstash) ─────────────────────────────────────────────────
REDIS_URL="rediss://default:<NEW_TOKEN>@<instance>.upstash.io:6379"

# ── WhatsApp / Meta ─────────────────────────────────────────────────
# Nao sao secrets (IDs publicos), mas deixados aqui pra centralizar
# OBSOLETO em V5.1: phone_id 1121381984386813 corresponde ao número antigo
# +5511945633305 (descontinuado). Número operacional novo: +5511926160159.
# Pegue o phone_id novo no Meta Business Manager > WhatsApp Manager.
WHATSAPP_PHONE_NUMBER_ID="<PHONE_ID_DO_NUMERO_5511926160159>"
WHATSAPP_BUSINESS_ACCOUNT_ID="2723969931308778"
# Secrets: rotacionar no Meta Business Manager
WHATSAPP_ACCESS_TOKEN="<NEW_META_SYSTEM_USER_TOKEN>"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="<NEW_HEX_32B · openssl rand -hex 32>"

# ── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_<NEW>"
STRIPE_WEBHOOK_SECRET="whsec_<NEW>"
# Price IDs · publicos, nao sao secrets
STRIPE_PRICE_IDS='{"plans":{"STARTER":{"product":"prod_XXX","monthly":"price_XXX","annual":"price_XXX"},"GROWTH":{"product":"prod_XXX","monthly":"price_XXX","annual":"price_XXX"},"SCALE":{"product":"prod_XXX","monthly":"price_XXX","annual":"price_XXX"},"BUSINESS":{"product":"prod_XXX","monthly":"price_XXX","annual":"price_XXX"}},"addons":{}}'

# ── LLMs ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-<NEW>"
OPENAI_API_KEY="sk-proj-<NEW>"
